# Pilih salah satu: claude atau openai
LLM_PROVIDER=claude

# API key dari Claude (console.anthropic.com) atau OpenAI (platform.openai.com)
LLM_API_KEY=sk-xxxxx

# API key dari Chatwoot (Settings > Account Settings > klik profile > Access Token)
CHATWOOT_API_KEY=xxxxx

# URL Chatwoot (kalau cloud, biarkan default)
CHATWOOT_API_URL=https://app.chatwoot.com
